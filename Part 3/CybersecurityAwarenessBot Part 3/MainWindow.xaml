<Window x:Class="CybersecurityAwarenessBotPart3.MainWindow"
        Background="#08152E"
WindowStartupLocation="CenterScreen"
ResizeMode="CanResize"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Threat Awareness Engine"
        Height="650" Width="1000">
    

    <Grid>
        <TabControl Background="#08152E"
            Foreground="White"
            Margin="10">

            <TabItem Header="Chatbot">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Name="ChatOutput"
                             Background="#12213F"
Foreground="White"
BorderBrush="#1CE0FF"
FontSize="14"
                 Grid.Row="0"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="5"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBox Name="UserInput"
                                 Background="#12213F"
Foreground="White"
BorderBrush="#1CE0FF"
                     Width="700"
                     Height="30"
                     Margin="5"/>

                        <Button Name="SendButton"
                                Background="#00D9FF"
Foreground="Black"
FontWeight="Bold"
BorderThickness="0"
                    Content="Send"
                                Click="SendButton_Click"
                                
                    Width="100"
                    Height="30"
                    Margin="5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Task Assistant">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBox Name="TaskTitleBox" Width="200" Margin="5"
         Background="#12213F"
         Foreground="White"
         BorderBrush="#1CE0FF"/>
                        <TextBox Name="TaskDescriptionBox" Width="250" Margin="5"
         Background="#12213F"
         Foreground="White"
         BorderBrush="#1CE0FF"/>
                        <ComboBox Name="PriorityBox" Width="120" Margin="5">
                            <ComboBoxItem Content="Low"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <DatePicker Name="TaskDueDatePicker" Margin="5"/>
                        <Button Name="AddTaskButton"
                                Background="#00D9FF"
Foreground="Black"
FontWeight="Bold"
BorderThickness="0"
        Content="Add Task"
        Width="100"
        Margin="5"
        Click="AddTaskButton_Click"/>
                        <Button Name="DeleteTaskButton"
                                Background="#00D9FF"
Foreground="Black"
FontWeight="Bold"
BorderThickness="0"
        Content="Delete Task"
        Width="100"
        Margin="5"
        Click="DeleteTaskButton_Click"/>
                    </StackPanel>

                    <ListBox Name="TaskListBox" Grid.Row="2" Margin="5"
         Background="#12213F"
         Foreground="White"
         BorderBrush="#1CE0FF"/>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="QuizQuestionText"
                               Foreground="White"
                   FontSize="18"
                   Margin="5"
                   TextWrapping="Wrap"/>

                    <ListBox Name="QuizOptionsList"
         Grid.Row="1"
         Margin="5"
         Height="200"
         Background="#12213F"
         Foreground="White"
         BorderBrush="#1CE0FF"/>

                    <Button Name="SubmitQuizButton"
                            Background="#00D9FF"
Foreground="Black"
FontWeight="Bold"
BorderThickness="0"
        Grid.Row="2"
        Content="Submit Answer"
        Width="150"
        Height="40"
        Margin="5"
        Click="SubmitQuizButton_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log">
                <Grid Margin="10">
                    <ListBox Name="ActivityLogListBox"
         Background="#12213F"
         Foreground="White"
         BorderBrush="#1CE0FF"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
